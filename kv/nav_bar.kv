        Label:
            font_name: 'MaterialIcons'
            text: ''
            font_size: sp(22)
            color: (0.75, 0.77, 0.95, 1) if app.current_screen == 'calendar' else (0.42, 0.44, 0.56, 1)
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            size_hint_y: 0.62
        Label:
