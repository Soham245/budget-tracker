                radius: [dp(14)]
        Label:
            font_name: 'MaterialIcons'
            text: ''
            font_size: sp(22)
            color: (0.75, 0.77, 0.95, 1) if app.current_screen == 'analytics' else (0.42, 0.44, 0.56, 1)
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            size_hint_y: 0.62
        Label:
            text: 'Analytics'
            font_size: sp(10)
            bold: app.current_screen == 'analytics'
            color: (0.75, 0.77, 0.95, 1) if app.current_screen == 'analytics' else (0.42, 0.44, 0.56, 1)
            halign: 'center'
            size_hint_y: 0.38

    # ── Calendar tab ──────────────────────────────────────────────────────────
