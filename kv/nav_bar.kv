            halign: 'center'
            size_hint_y: 0.38

    # ── Settings tab ───────────────────────────────────────────────────────────────────
    # MaterialIcons  (U+E8B8) = "settings" gear.
    NavButton:
        orientation: 'vertical'
        spacing: 0
        padding: dp(4), dp(6), dp(4), dp(4)
        on_release: app.go_to('settings')
        canvas.before:
